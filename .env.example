APP_NAME="Apna Invoice"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=http://localhost:8000

# --- PRODUCTION CHECKLIST ---
# Before deploying, set the following in the production .env:
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://your-production-domain
#   SESSION_SECURE_COOKIE=true
#   MAIL_MAILER=smtp           (configure real SMTP — password reset & email verification need this)
# Then run: php artisan config:cache && php artisan route:cache && php artisan view:cache

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Prefer daily in production so logs rotate instead of growing forever.
# Set LOG_DAILY_DAYS to control retention (default 14 in config/logging.php).
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Default debug in .env; flip to `warning` or `error` in production .env.
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Cloudflare Turnstile (captcha on login / register / forgot-password) ---
# Required in production — the validation rule fails closed when APP_ENV=production
# and either key is blank, which blocks all auth attempts. Grab free keys at
# https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Payment reminders ---
# REMINDERS_ENABLED=false disables the daily scheduled reminder job entirely.
# REMINDERS_SEND_HOUR is 0-23 in the app timezone (Asia/Kolkata).
REMINDERS_ENABLED=true
REMINDERS_SEND_HOUR=8

# --- Contact form ---
# Inbox that receives messages from the /contact page. Falls back to
# MAIL_FROM_ADDRESS if left blank.
CONTACT_TO_EMAIL=

# --- Optional WhatsApp / SMS gateways (stubs today; wire later) ---
# WhatsApp BSP (Twilio, Meta Cloud API, Gupshup, Interakt). Until a token is
# set, WhatsApp reminders fall back to manual wa.me click-through links.
# WA_BSP_TOKEN=
#
# SMS gateway (MSG91, Twilio, Fast2SMS). Requires DLT registration in India.
# SMS_API_KEY=
